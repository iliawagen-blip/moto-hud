{
  "name": "moto-hud",
  "version": "1.0.0",
  "private": true,
  "description": "Мото ИЛС — HUD-навигатор для мотоцикла",
  "scripts": {
    "dev": "node scripts/build-web.mjs && node scripts/regression-results-manifest.mjs && npx --yes serve -l 3456 -c serve.json .",
    "fuel:spike": "node scripts/fuel-gdzapravka-spike.mjs",
    "build": "node scripts/build-web.mjs && node scripts/regression-results-manifest.mjs",
    "nav:replay": "node scripts/nav-replay.mjs --baseline fixtures/baseline_v1.json",
    "nav:baseline": "node scripts/nav-replay.mjs --capture --baseline fixtures/baseline_v1.json",
    "nav:test": "node scripts/nav-replay.mjs --self-test",
    "converge:report": "node scripts/converge-report.mjs",
    "funnel:report": "node scripts/telemetry-funnel-report.mjs",
    "prod:smoke": "node scripts/prod-smoke.mjs",
    "yandex:test": "node scripts/yandex-link-test.mjs",
    "yandex:export:test": "node scripts/yandex-export-test.mjs",
    "trip:fuel:test": "node scripts/trip-fuel-test.mjs",
    "trip:rebuild:test": "node scripts/trip-rebuild-test.mjs",
    "trip:extract": "node scripts/extract-trip-jul2026.mjs",
    "interchange:test": "node scripts/interchange-test.mjs",
    "regression:sim:moscow": "node regression/scripts/run-sim-moscow.mjs",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "regression:validate-schema": "node regression/scripts/validate-schema.mjs",
    "regression:generate": "node regression/scripts/generate-waypoints.mjs",
    "regression:fetch:motohud": "node regression/scripts/fetch-motohud-routes.mjs",
    "regression:fetch:gh": "node regression/scripts/fetch-graphhopper.mjs",
    "regression:fetch:ors": "node regression/scripts/fetch-openrouteservice.mjs",
    "regression:import:yandex": "node regression/scripts/import-yandex-fixture.mjs",
    "regression:fetch:yandex": "node regression/scripts/fetch-yandex-web.mjs",
    "regression:metrics": "node regression/scripts/compute-metrics.mjs",
    "regression:sim": "node regression/scripts/run-sim.mjs",
    "regression:report": "node regression/scripts/generate-report.mjs",
    "regression:review": "node regression/scripts/review-worst.mjs",
    "regression:nightly": "node regression/scripts/run-nightly.mjs",
    "regression:smoke": "node regression/scripts/run-nightly.mjs --fixtures 5 --skip-yandex",
    "regression:state": "node regression/scripts/update-state.mjs",
    "regression:rebuild-sim-summary": "node regression/scripts/rebuild-sim-summary.mjs",
    "regression:gh-burn": "node regression/scripts/gh-burn-loop.mjs",
    "regression:cleanup": "node regression/scripts/cleanup-cache.mjs"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor-community/keep-awake": "^6.0.0",
    "@capacitor-community/text-to-speech": "^6.1.0",
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/geolocation": "^7.1.2",
    "@capacitor/local-notifications": "^7.0.7",
    "fflate": "^0.8.3",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@turf/turf": "^7.2.0",
    "dotenv": "^16.4.7",
    "esbuild": "^0.28.1",
    "p-queue": "^8.1.0",
    "playwright": "^1.52.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  }
}
